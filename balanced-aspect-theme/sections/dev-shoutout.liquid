<div class="dev-shoutout-wrapper" style="background-color: {{ section.settings.bg_color }}; padding: 40px 20px; text-align: center;">
  
  {% if section.settings.headshot != blank %}
    {%- comment -%} Wrap the image in a link if a URL is provided {%- endcomment -%}
    {% if section.settings.linkedin_url != blank %}<a href="{{ section.settings.linkedin_url }}" target="_blank">{% endif %}
      <img 
        src="{{ section.settings.headshot | image_url: width: 150 }}" 
        alt="Developer Headshot" 
        style="width: 150px; height: 150px; object-fit: cover; border-radius: 50%; margin-bottom: 20px; border: 3px solid {{ section.settings.text_color }}; transition: transform 0.3s ease;"
        onmouseover="this.style.transform='scale(1.05)'"
        onmouseout="this.style.transform='scale(1)'"
      >
    {% if section.settings.linkedin_url != blank %}</a>{% endif %}
  {% endif %}

  <h2 style="color: {{ section.settings.text_color }};">{{ section.settings.heading }}</h2>
  <p style="color: {{ section.settings.text_color }}; font-size: 18px; max-width: 600px; margin: 0 auto 20px auto;">{{ section.settings.bio }}</p>

  {% if section.settings.linkedin_url != blank %}
    <a href="{{ section.settings.linkedin_url }}" 
       target="_blank" 
       style="display: inline-block; padding: 10px 25px; background: {{ section.settings.text_color }}; color: {{ section.settings.bg_color }}; text-decoration: none; border-radius: 5px; font-weight: bold;">
      View My Profile
    </a>
  {% endif %}
</div>

{% schema %}
{
  "name": "Dev Shoutout",
  "settings": [
    {
      "type": "image_picker",
      "id": "headshot",
      "label": "Profile Headshot"
    },
    {
      "type": "text",
      "id": "linkedin_url",
      "label": "LinkedIn Profile URL"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hello, I'm a Junior Shopify Dev!"
    },
    {
      "type": "textarea",
      "id": "bio",
      "label": "Short Bio",
      "default": "I built this custom section using the Shopify CLI and Liquid."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f0f8ff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111111"
    }
  ],
  "presets": [
    {
      "name": "Dev Shoutout"
    }
  ]
}
{% endschema %}